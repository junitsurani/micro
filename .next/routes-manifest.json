{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/fonts(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/images(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/access",
      "regex": "^/access(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/access(?:/)?$"
    },
    {
      "page": "/experience",
      "regex": "^/experience(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/experience(?:/)?$"
    },
    {
      "page": "/icon.svg",
      "regex": "^/icon\\.svg(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.svg(?:/)?$"
    },
    {
      "page": "/opengraph-image",
      "regex": "^/opengraph\\-image(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/opengraph\\-image(?:/)?$"
    },
    {
      "page": "/privacy-policy",
      "regex": "^/privacy\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/privacy\\-policy(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/secretdoor",
      "regex": "^/secretdoor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/secretdoor(?:/)?$"
    },
    {
      "page": "/secretdoor/dashboard",
      "regex": "^/secretdoor/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/secretdoor/dashboard(?:/)?$"
    },
    {
      "page": "/secretdoor/dashboard/events",
      "regex": "^/secretdoor/dashboard/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/secretdoor/dashboard/events(?:/)?$"
    },
    {
      "page": "/secretdoor/dashboard/waitlist",
      "regex": "^/secretdoor/dashboard/waitlist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/secretdoor/dashboard/waitlist(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/terms-conditions",
      "regex": "^/terms\\-conditions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms\\-conditions(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}