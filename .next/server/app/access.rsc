10:T906,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is MICRO?","acceptedAnswer":{"@type":"Answer","text":"MICRO is a sensory movement studio in Chelsea, London, one of the city’s few Lagree Microformer studios. It brings together movement, recovery and nutrition in a space architected to settle the nervous system before the body moves. Opening on Sloane Avenue, 2026."}},{"@type":"Question","name":"Where is MICRO?","acceptedAnswer":{"@type":"Answer","text":"60 Sloane Avenue, Chelsea, London SW3 3AP."}},{"@type":"Question","name":"Is this Lagree?","acceptedAnswer":{"@type":"Answer","text":"The Lagree Microformer sits at the centre, but it isn’t the whole of it. Five proprietary formats are built around it, developed in-house and unique to the studio."}},{"@type":"Question","name":"Who is MICRO for?","acceptedAnswer":{"@type":"Answer","text":"For the body that has done everything and still feels it, and for the body just beginning. MICRO is for the exhausted and the curious, the first-timer and the lifelong athlete. Not only movement, but recovery, nutrition and a space that settles the nervous system, meeting you where you are."}},{"@type":"Question","name":"What happens inside?","acceptedAnswer":{"@type":"Answer","text":"Some things are better felt than explained. The five proprietary formats reveal themselves to founding members of Circle 001 first."}},{"@type":"Question","name":"How does membership work?","acceptedAnswer":{"@type":"Answer","text":"Membership is a tiered approach, centred on the depth of practice, not a ladder of packages. You won’t find a beginner option and a premium one here; you’ll find a way in, and a way deeper. Founding access opens first to Circle 001, sixty members, by invitation."}},{"@type":"Question","name":"Is there food?","acceptedAnswer":{"@type":"Answer","text":"Nutrition is part of the practice, not an afterthought, every modality chosen for its merit, not its moment."}},{"@type":"Question","name":"When does Chelsea open?","acceptedAnswer":{"@type":"Answer","text":"Autumn 2026. Founding Circle 001 members are granted first access."}},{"@type":"Question","name":"How does booking work?","acceptedAnswer":{"@type":"Answer","text":"Booking opens to the founding list first, in phases."}}]}d:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$10"}}],["$","$L9",null,{}],["$","$La",null,{"children":[["$","main",null,{"className":"access-page","children":[["$","$L11",null,{}],["$","section",null,{"className":"access-capture","id":"access-form","aria-labelledby":"access-capture-title","children":[["$","div",null,{"className":"access-capture-copy","children":[["$","div",null,{"className":"access-kicker","children":[["$","span",null,{"aria-hidden":"true"}],"Founding access"]}],["$","h1",null,{"id":"access-capture-title","children":["Be part of the first circle,",["$","br",null,{}],"before the doors open."]}],["$","div",null,{"className":"access-capture-panel","aria-hidden":"true"}]]}],["$","$L12",null,{}]]}],["$","section",null,{"className":"access-private","aria-labelledby":"access-private-title","children":["$","div",null,{"className":"access-private-grid","children":[["$","div",null,{"className":"access-private-copy","children":[["$","h2",null,{"id":"access-private-title","children":["Private access,",["$","br",null,{}],"for a quieter",["$","br",null,{}],"kind of strength."]}],["$","span",null,{"className":"access-private-rule","aria-hidden":"true"}],["$","p",null,{"children":"The founding list for Chelsea. Movement, recovery, nutrition and sensory design, held as one practice."}]]}],"$L13"]}]}],"$L14","$L15","$L16"]}],"$L17"]}]],null,"$L18"]}]
